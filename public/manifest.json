{
  "manifest_version": 3,
  "name": "SalahSync",
  "version": "2.0",
  "description": "A browser extension for UC Davis students to sync their classes with the times of Davis Masjid",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.aladhan.com/*",
    "https://my.ucdavis.edu/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://my.ucdavis.edu/schedulebuilder/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "SalahSync 16x16.png",
    "48": "SalahSync 48x48.png",
    "128": "SalahSync 128x128.png"
  },
  "action": {
    "default_icon": "SalahSync 48x48.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
